#include <WiFi.h>
#include <PubSubClient.h>
#include "config.h" // 🔴 ดึงการตั้งค่าทั้งหมดจากไฟล์ config.h มาใช้

WiFiClient espClient;
PubSubClient client(espClient);

void setup() {
  Serial.begin(115200);
  setup_wifi();
  client.setServer(mqtt_server, mqtt_port);
  client.setCallback(callback);
}

void loop() {
  if (!client.connected()) {
    reconnect();
  }
  client.loop();
}

void setup_wifi() {
  delay(10);
  Serial.println();
  Serial.print("Connecting to ");
  Serial.println(ssid); // ดึงค่า ssid มาจาก config.h
  WiFi.begin(ssid, password); // ดึงค่า password มาจาก config.h
  
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("");
  Serial.print("WiFi connected - ESP32 IP address: ");
  Serial.println(WiFi.localIP());
}

void callback(char* topic, byte* payload, unsigned int length) {
  String receivedTopic = String(topic);
  
  // เช็คว่าหัวข้อตรงกับชื่อเครื่องเราไหม (ดึงค่า esp32_name จาก config.h)
  if (receivedTopic.equals(String(mqtt_topic) + esp32_name)) {
    String command = "";
    for (int i = 0; i < length; i++) {
      command += (char)payload[i];
    }
    Serial.println("Received command: " + command);
    
    if (command == "get_data") {
      float sensorValue = random(0, 100);
      String response = "Sensor data from " + String(esp32_name) + ": " + String(sensorValue);
      client.publish("/ESP32/response", response.c_str());
      Serial.println("Published response: " + response);
    }
  }
}

void reconnect() {
  while (!client.connected()) {
    Serial.print("Attempting MQTT connection...");
    String clientId = "ESP32Client-" + String(random(0xffff), HEX);
    
    if (client.connect(clientId.c_str(), mqtt_username, mqtt_password)) {
      Serial.println("connected");
      String subscribeTopic = String(mqtt_topic) + esp32_name;
      client.subscribe(subscribeTopic.c_str());
    } else {
      Serial.print("failed, rc=");
      Serial.print(client.state());
      Serial.println(" try again in 5 seconds");
      delay(5000);
    }
  }
}